# FastAPI Backend Environment Variables
# Copy this file to .env for local development or configure in Render / Railway secrets

# Project Metadata
PROJECT_NAME="Doctor Appointment System API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
LOG_LEVEL="INFO"

# Security & Authentication (MUST change SECRET_KEY in production to at least 32 random characters)
SECRET_KEY="super-secret-key-change-this-in-production-to-at-least-32-chars"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL Database Connection String (format: postgresql://user:password@host:port/dbname)
DATABASE_URL="postgresql://postgres:password@localhost:5432/doctor_appointment_db"

# CORS Allowed Origins (JSON array string format)
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","https://your-frontend-domain.vercel.app"]'
